{
  "name": "@executioncontextprotocol/workspace",
  "version": "0.0.4",
  "description": "Execution Control Protocol (ECP) — open specification for defining, packaging, versioning, and deploying AI agent environments",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/spec packages/runtime packages/cli && npm run generate:schema --workspace=@executioncontrolprotocol/spec",
    "build:clean": "tsc -b packages/spec packages/runtime packages/cli --clean",
    "lint": "eslint . && markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules'",
    "lint:ts": "eslint .",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules'",
    "generate:schema": "npm run generate:schema --workspace=@executioncontrolprotocol/spec",
    "validate": "npm run validate --workspace=@executioncontrolprotocol/spec",
    "docs": "npm run dev --workspace=@executioncontrolprotocol/docs",
    "docs:typedoc": "npm run build:typedoc --workspace=@executioncontrolprotocol/docs",
    "test": "npm run build && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:watch": "vitest \"packages/spec/test\" \"packages/runtime/test\" \"packages/cli/test\" --exclude \"packages/runtime/test/integration/**\" --exclude \"packages/runtime/test/e2e/**\"",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run \"packages/spec/test\" \"packages/runtime/test\" \"packages/cli/test\" --exclude \"packages/runtime/test/integration/**\" --exclude \"packages/runtime/test/e2e/**\"",
    "test:integration": "vitest run packages/runtime/test/integration",
    "test:e2e": "vitest run packages/runtime/test/e2e",
    "check": "npm run build && npm run lint && npm run validate && npm run test:unit && npm run test:integration && npm run test:e2e",
    "version:bump": "node scripts/bump-workspace-versions.mjs",
    "version:check-vs-npm": "node scripts/check-version-gt-published.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "markdownlint-cli2": "^0.17.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18",
    "semver": "^7.6.0"
  }
}
