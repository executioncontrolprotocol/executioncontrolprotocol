{
  "name": "executioncontextprotocol",
  "version": "0.3.0",
  "description": "Execution Control Protocol (ECP) — open specification for defining, packaging, versioning, and deploying AI agent environments",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/spec && npm run build --workspace=@ecp/runtime",
    "lint": "eslint . && markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules'",
    "lint:ts": "eslint .",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules'",
    "generate:schema": "npm run generate:schema --workspace=@ecp/spec",
    "validate": "npm run validate --workspace=@ecp/spec",
    "docs": "npm run build --workspace=@ecp/docs",
    "check": "npm run build && npm run generate:schema && npm run lint && npm run validate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "markdownlint-cli2": "^0.17.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
