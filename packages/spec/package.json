{
  "name": "@executioncontrolprotocol/spec",
  "version": "0.0.4",
  "description": "ECP specification types, JSON Schema generation, and validation",
  "license": "Apache-2.0",
  "homepage": "https://github.com/executioncontrolprotocol/executioncontrolprotocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/executioncontrolprotocol/executioncontrolprotocol.git",
    "directory": "packages/spec"
  },
  "bugs": {
    "url": "https://github.com/executioncontrolprotocol/executioncontrolprotocol/issues"
  },
  "keywords": [
    "ecp",
    "execution-control-protocol",
    "mcp",
    "model-context-protocol",
    "agents",
    "spec",
    "schema",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/types/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "generate:schema": "ts-json-schema-generator -p src/types/ecp.ts -t ECPContext --additional-properties --no-type-check -o dist/ecp-context.schema.json",
    "validate": "node dist/validate.js",
    "check": "npm run build && npm run generate:schema && npm run validate"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "ts-json-schema-generator": "^2.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
