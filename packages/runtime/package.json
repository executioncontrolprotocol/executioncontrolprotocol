{
  "name": "@executioncontrolprotocol/runtime",
  "version": "0.0.4",
  "description": "ECP runtime engine — loads, validates, and executes Context manifests",
  "license": "Apache-2.0",
  "homepage": "https://github.com/executioncontrolprotocol/executioncontrolprotocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/executioncontrolprotocol/executioncontrolprotocol.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/executioncontrolprotocol/executioncontrolprotocol/issues"
  },
  "keywords": [
    "ecp",
    "execution-control-protocol",
    "mcp",
    "model-context-protocol",
    "agents",
    "runtime",
    "engine",
    "orchestration"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js",
      "default": "./dist/extensions/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.0",
    "@executioncontrolprotocol/spec": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ajv": "^8.17.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.0.0",
    "sql.js": "^1.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
