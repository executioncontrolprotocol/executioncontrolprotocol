{
  "name": "@executioncontrolprotocol/runtime",
  "version": "0.3.0",
  "description": "ECP runtime engine — loads, validates, and executes Context manifests",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js",
      "default": "./dist/extensions/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.0",
    "@executioncontrolprotocol/spec": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ajv": "^8.17.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
